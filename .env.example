# Classifier model (used to evaluate memory systems during benchmark)
CLASSIFIER_MODEL=openrouter/openai/gpt-oss-120b
CLASSIFIER_API_BASE=https://openrouter.ai/api/v1
CLASSIFIER_API_KEY=your_openrouter_api_key_here

# NOTE: the proposer now runs through the Claude Code CLI (subscription auth),
# so PROPOSER_* below is no longer required for evolution.
# PROPOSER_MODEL=openrouter/anthropic/claude-opus-4-6
# PROPOSER_API_BASE=https://openrouter.ai/api/v1
# PROPOSER_API_KEY=your_openrouter_api_key_here

# Harbor (agent task): model the candidate agent calls inside the harness during
# evaluation. HARBOR_API_BASE is optional (route to an OpenAI-compatible endpoint).
HARBOR_MODEL=anthropic/claude-opus-4-6
# HARBOR_API_BASE=https://api.deepseek.com

# Optional: local LLM server (overrides API-based models if set)
# LOCAL_LLM_HOST=localhost
# LOCAL_LLM_PORT=30000
